    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "quiz_files",
          "accept": [
            "text/plain",
            "application/json"
          ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
